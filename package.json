{
  "name": "react-data-grid-table-excel",
  "version": "0.1.1",
  "description": "A spreadsheet-like React data grid with editing, sorting, and Ant Design styling",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config demo/vite.config.ts",
    "build": "tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview --config demo/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XanderDwyl/react-data-grid-table-excel.git"
  },
  "peerDependencies": {
    "antd": ">=5.0.0",
    "antd-style": ">=3.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "xlsx-js-style": ">=1.2.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^5.5.0",
    "@types/node": "^25.4.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "antd": "^5.22.0",
    "antd-style": "^3.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "xlsx-js-style": "^1.2.0"
  },
  "keywords": [
    "react",
    "data-grid",
    "table",
    "spreadsheet",
    "editable",
    "antd",
    "ant-design",
    "typescript"
  ],
  "author": "Alexjander Bacalso <janderbacalso@gmail.com>",
  "bugs": {
    "url": "https://github.com/XanderDwyl/react-data-grid-table-excel/issues"
  },
  "homepage": "https://github.com/XanderDwyl/react-data-grid-table-excel#readme",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {}
}
